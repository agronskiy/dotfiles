#!/usr/bin/env python3
"""claude-skill: manage Claude Code skills tracked in dotfiles

Usage:
  claude-skill [--local] <skill-name> "<trigger description>"   # create
  claude-skill remove <skill-name>                              # remove
"""

import os
import re
import shutil
import sys
from pathlib import Path
from textwrap import dedent

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------
RESET  = "\033[0m"
BOLD   = "\033[1m"
RED    = "\033[1;31m"
GREEN  = "\033[1;32m"
YELLOW = "\033[1;33m"

def ok(msg):   print(f"{GREEN}✓{RESET} {msg}")
def warn(msg): print(f"{YELLOW}⚠{RESET} {msg}")
def err(msg):  print(f"{RED}Error:{RESET} {msg}", file=sys.stderr)

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
HOME           = Path.home()
DOTFILES       = Path(os.environ.get("DOTFILES", HOME / ".dotfiles"))
DOTFILES_LOCAL = HOME / ".dotfiles-local"
SKILLS_DIR     = HOME / ".claude" / "skills"

PUB_SKILLS   = DOTFILES / ".claude" / "skills"
LOCAL_SKILLS = DOTFILES_LOCAL / ".claude" / "skills"

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
USAGE = dedent("""\
    Usage:
      claude-skill [--local] <skill-name> "<trigger description>"
      claude-skill remove <skill-name>

    Commands:
      (default)        Create a new skill
      remove           Remove skill: unlinks from ~/.claude/skills/ and
                       deletes from the source dotfiles repo

    Flags (create only):
      --local          Create in ~/.dotfiles-local/.claude/skills/ (private)
                       Default: ~/.dotfiles/.claude/skills/ (public)

    Examples:
      claude-skill my-workflow "Use when the user asks to run the deploy pipeline"
      claude-skill --local local-oncall "Use when the user asks about on-call rotation"
      claude-skill remove my-workflow
""")

# ---------------------------------------------------------------------------
# Create
# ---------------------------------------------------------------------------
def cmd_create(args):
    local = False
    if args and args[0] == "--local":
        local = True
        args = args[1:]

    if len(args) < 2:
        err("missing arguments")
        print()
        print(USAGE)
        sys.exit(1)

    skill_name, description = args[0], args[1]

    if not re.match(r"^[a-z][a-z0-9-]*$", skill_name):
        err("skill name must be lowercase kebab-case (e.g. my-skill)")
        sys.exit(1)

    if local and not skill_name.startswith("local-"):
        warn(f"local skills should be prefixed with 'local-' (e.g. local-{skill_name})")
        if sys.stdin.isatty():
            answer = input("Continue anyway? [y/N] ")
            if answer.lower() != "y":
                sys.exit(1)
        else:
            warn("Non-interactive mode — proceeding without confirmation.")

    if local:
        if not DOTFILES_LOCAL.is_dir():
            err("~/.dotfiles-local does not exist. Create the private repo first.")
            sys.exit(1)
        repo, label = DOTFILES_LOCAL, "local"
    else:
        repo, label = DOTFILES, "public"

    skill_dir = repo / ".claude" / "skills" / skill_name
    if skill_dir.exists():
        err(f"skill '{skill_name}' already exists at {skill_dir}")
        sys.exit(1)

    (skill_dir / "references").mkdir(parents=True)

    (skill_dir / "SKILL.md").write_text(dedent(f"""\
        ---
        name: {skill_name}
        description: {description}
        version: 1.0.0
        ---

        # {skill_name}

        TODO: describe what this skill helps with.

        ## When This Skill Applies

        {description}

        ## Instructions

        TODO: add step-by-step instructions or reference materials.

        See `references/notes.md` for detailed supporting material.
    """))

    (skill_dir / "references" / "notes.md").write_text(dedent(f"""\
        # {skill_name} — Reference Notes

        Add detailed reference material here.
        This file is only loaded when the skill activates — keep SKILL.md brief.
    """))

    ok(f"Created skill '{BOLD}{skill_name}{RESET}' [{label}]")
    print(f"  {skill_dir / 'SKILL.md'}")

    SKILLS_DIR.mkdir(parents=True, exist_ok=True)
    dst = SKILLS_DIR / skill_name
    dst.unlink(missing_ok=True)
    dst.symlink_to(skill_dir.resolve())
    ok(f"Linked → {dst}")

    print()
    print("Next steps:")
    print(f"  1. Edit {skill_dir}/SKILL.md — refine the trigger description")
    print(f"  2. Edit {skill_dir}/references/notes.md — add detailed reference material")
    print(f"  3. Commit in the {label} dotfiles repo")
    print( "  4. Run 'claude-setup --status' to verify")

# ---------------------------------------------------------------------------
# Remove
# ---------------------------------------------------------------------------
def cmd_remove(skill_name: str):
    dst = SKILLS_DIR / skill_name

    if not dst.exists() and not dst.is_symlink():
        err(f"skill '{skill_name}' not found in {SKILLS_DIR}")
        sys.exit(1)

    # Determine source
    if dst.is_symlink():
        target = Path(os.readlink(dst))
        if str(target).startswith(str(PUB_SKILLS)):
            label, source_dir = "public", target
        elif str(target).startswith(str(LOCAL_SKILLS)):
            label, source_dir = "local", target
        else:
            label, source_dir = "other", target
    else:
        label, source_dir = "direct", None

    # Confirm
    if label == "direct":
        warn(f"'{skill_name}' is a direct directory (not tracked in dotfiles).")
        warn("Removing it will permanently delete the files.")
    else:
        print(f"Will remove skill '{BOLD}{skill_name}{RESET}' [{label}]:")
        print(f"  symlink:    {dst}")
        print(f"  source dir: {source_dir}")

    if sys.stdin.isatty():
        answer = input("Confirm removal? [y/N] ")
        if answer.lower() != "y":
            print("Aborted.")
            sys.exit(0)
    else:
        warn("Non-interactive mode — proceeding without confirmation.")

    # Remove symlink
    dst.unlink(missing_ok=True)
    ok(f"Removed symlink {dst}")

    # Remove source directory (only if tracked in our repos)
    if source_dir and label in ("public", "local"):
        if source_dir.exists():
            shutil.rmtree(source_dir)
            ok(f"Deleted source directory {source_dir}")
        print()
        print(f"Remember to commit the deletion in the {label} dotfiles repo.")
    elif label == "direct":
        if dst.exists():
            shutil.rmtree(dst)
            ok(f"Deleted {dst}")

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
def main():
    args = sys.argv[1:]

    if not args or "-h" in args or "--help" in args:
        print(USAGE)
        sys.exit(0 if not args else 1)

    if args[0] == "remove":
        if len(args) < 2:
            err("missing skill name")
            print(USAGE)
            sys.exit(1)
        cmd_remove(args[1])
    else:
        cmd_create(args)


if __name__ == "__main__":
    main()
